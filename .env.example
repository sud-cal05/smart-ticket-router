# Copy to .env and fill in your real key. .env is git-ignored.
OPENAI_API_KEY=sk-your-key-here

# Model config (overridable without code changes)
ROUTER_MODEL=gpt-4o-mini
ROUTER_TEMPERATURE=0

# Optional features (default off)
ROUTER_DYNAMIC_FEWSHOT=false
ROUTER_TIERED_ESCALATION=false
ROUTER_ESCALATION_THRESHOLD=0.6
ROUTER_STRONG_MODEL=gpt-4o